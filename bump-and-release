#!/usr/bin/env bash
#
# bump-and-release: set the mod version, tag it, push, and publish a release.
#
# Usage:
#   ./bump-and-release v0.1.1            bump to 0.1.1, build, commit, tag, push, release
#   ./bump-and-release v0.1.1 --skip-build   same, but don't build locally first
#
# What it does:
#   1. Checks the repo is clean, on the default branch, and the tag is new.
#   2. Builds the jar locally (catches breakage before CI), unless --skip-build.
#   3. Writes mod_version in gradle.properties.
#   4. Commits the bump and pushes the branch.
#   5. Creates and pushes an annotated tag, which triggers the CurseForge
#      release workflow (.github/workflows/release.yml).
#   6. Creates a GitHub Release with auto-generated notes.
#
# Requires: git, gh (authenticated). A JDK is optional (used only for the local build).

set -euo pipefail

die()  { printf '\033[31merror:\033[0m %s\n' "$1" >&2; exit 1; }
info() { printf '\033[36m==>\033[0m %s\n' "$1"; }

SKIP_BUILD=0
TAG=""
for arg in "$@"; do
  case "$arg" in
    --skip-build)  SKIP_BUILD=1 ;;
    -h|--help)     awk 'NR>1 && /^#/{sub(/^# ?/,"");print;next} NR>1{exit}' "$0"; exit 0 ;;
    v*)            TAG="$arg" ;;
    *)             die "unknown argument: $arg" ;;
  esac
done

[ -n "$TAG" ] || die "usage: ./bump-and-release vX.Y.Z [--skip-build]"
[[ "$TAG" =~ ^v[0-9]+\.[0-9]+\.[0-9]+([.-][0-9A-Za-z.]+)?$ ]] \
  || die "version must look like v1.2.3 (got: $TAG)"
VERSION="${TAG#v}"

cd "$(dirname "$0")"

command -v git >/dev/null || die "git not found"
command -v gh  >/dev/null || die "gh (GitHub CLI) not found"
gh auth status >/dev/null 2>&1 || die "gh is not authenticated. Run: gh auth login"
git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "not a git repository"

BRANCH="$(git symbolic-ref --short HEAD)"
DEFAULT="$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|^origin/||')"
DEFAULT="${DEFAULT:-main}"
[ "$BRANCH" = "$DEFAULT" ] || die "release from '$DEFAULT', not '$BRANCH'"

[ -z "$(git status --porcelain)" ] || die "working tree is dirty. Commit or stash first"

info "fetching origin..."
git fetch --quiet origin "$BRANCH" --tags

git rev-parse -q --verify "refs/tags/$TAG" >/dev/null \
  && die "tag $TAG already exists locally"
git ls-remote --exit-code --tags origin "$TAG" >/dev/null 2>&1 \
  && die "tag $TAG already exists on origin"

LOCAL="$(git rev-parse @)"
UPSTREAM="$(git rev-parse '@{u}' 2>/dev/null || echo "$LOCAL")"
[ "$LOCAL" = "$UPSTREAM" ] || die "local '$BRANCH' is out of sync with origin. Pull or push first"

CURRENT="$(grep '^mod_version=' gradle.properties | cut -d= -f2)"
[ "$CURRENT" != "$VERSION" ] || die "mod_version is already $VERSION"
info "version: $CURRENT -> $VERSION"

if [ "$SKIP_BUILD" -eq 0 ]; then
  # Auto-find a JDK on common WSL/Linux paths if one isn't already set up.
  if [ -z "${JAVA_HOME:-}" ] && ! command -v java >/dev/null 2>&1; then
    for d in /usr/lib/jvm/java-21-* /usr/lib/jvm/*21*; do
      [ -x "$d/bin/java" ] && export JAVA_HOME="$d" && break
    done
  fi
  if [ -n "${JAVA_HOME:-}" ] || command -v java >/dev/null 2>&1; then
    info "building (use --skip-build to skip)..."
    ./gradlew --quiet clean build
  else
    info "no JDK found, skipping local build (CI will build)"
  fi
fi

# Apply the version bump.
sed -i.bak "s/^mod_version=.*/mod_version=$VERSION/" gradle.properties && rm -f gradle.properties.bak

git add gradle.properties
git commit -m "chore: release $TAG"
info "pushing $BRANCH..."
git push origin "$BRANCH"

info "tagging $TAG..."
git tag -a "$TAG" -m "Harder Hordes $TAG"
git push origin "$TAG"

info "creating GitHub release..."
gh release create "$TAG" --title "Harder Hordes $TAG" --generate-notes

info "done. The release workflow will build and upload to CurseForge:"
echo "    https://github.com/$(gh repo view --json nameWithOwner -q .nameWithOwner)/actions/workflows/release.yml"
